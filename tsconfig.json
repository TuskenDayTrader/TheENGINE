{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "allowJs": true,
    "checkJs": true,
    "noEmit": true,
    "strict": true,
    "types": ["node"],
    "lib": ["ES2023", "DOM"],
    "skipLibCheck": true
  },
  "include": ["apps/**/*.js", "scripts/**/*.js", "tests/**/*.js"]
}
